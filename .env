# .env is better suited for public variables, ie, variables that should not committed
# For secret variables use the ProposeEnvVariable tool

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__

# Laravel Backend Configuration
# For production, set VITE_API_URL to your Laravel API URL
# For development, leave it empty to use the Vite dev proxy (proxies to http://localhost:8000)
VITE_API_URL=
